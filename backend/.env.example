# ── Cohere ────────────────────────────────────────────────────────────────────
COHERE_API_KEY=your-cohere-api-key

# ── Database ───────────────────────────────────────────────────────────────────
# Local (SQLite):
DATABASE_URL=sqlite:///./telkom_chatbot.db
# Production (Railway PostgreSQL — Railway otomatis inject ini):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_PATH=./chroma_data

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=ganti-dengan-random-string-panjang-minimal-32-karakter
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Upload ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── Admin default (seed pertama kali) ─────────────────────────────────────────
ADMIN_EMAIL=admin@telkomuniversity.ac.id
ADMIN_PASSWORD=ganti-password-ini

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local:
CORS_ORIGINS=http://localhost:3000
# Production (isi setelah dapat URL Vercel):
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
